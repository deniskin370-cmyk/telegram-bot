# Токен бота от @BotFather
BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# Ваш Telegram ID (создатель бота — получает права администратора автоматически)
# Узнать свой ID: написать боту @userinfobot
CREATOR_ID=YOUR_TELEGRAM_ID_HERE

# Telegram ID пользователя @Neworsi (для автоотправки подарков)
# Узнать ID: написать боту @userinfobot или @getmyid_bot
NEWORSI_USER_ID=YOUR_NEWORSI_TELEGRAM_ID_HERE
